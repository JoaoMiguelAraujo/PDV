# =============================================================================
# PDV — Software Service Open Delivery v1.7
# =============================================================================

# --- Banco (obrigatório) ---
# Em dev local:
#   DATABASE_URL=mysql://root:senha@localhost:3306/pdv
# No Coolify, use a variável que o serviço MySQL injeta.
DATABASE_URL=mysql://user:pass@host:3306/pdv

# --- Segredos (obrigatórios) ---
# AUTH_SECRET é usado para:
#   1) HKDF → chave AES-256-GCM que cifra clientSecret de cada merchant em repouso
#   2) Assinatura HMAC do cookie de sessão do operador
# Mínimo 32 caracteres. NUNCA mudar em produção (invalida segredos cifrados).
AUTH_SECRET=troque-isto-por-uma-string-aleatoria-de-no-minimo-32-chars

# Senha do operador (login do KDS). Hash bcrypt feito em memória no boot.
ADMIN_PASSWORD=trocar

# --- URL pública (obrigatória) ---
# URL que o menuGo usará no orderURL (não usado pelo PDV em si, mas exposto
# nos logs e na tela de Settings para você conferir).
APP_URL=https://pdv.example.com

# --- Servidor (opcionais) ---
PORT=4003

# --- Comportamento automático (opcionais) ---
# Valores INICIAIS — a UI sobrescreve via tabela Setting (Settings.auto_mode).
AUTO_MODE_DEFAULT=0
AUTO_CONFIRM_DELAY_MS=2000
AUTO_PREPARING_DELAY_MS=5000
AUTO_DELIVERED_DELAY_MS=10000

# Default global: se ligado, o /confirm envia header X-Mock-Payments: PREPAID
# para o menuGo (paga o pedido na confirmação). Pode ser sobrescrito no Setting.
PAY_ON_CONFIRM_DEFAULT=1

# Margem (ms) antes do expires_at para forçar refresh do token OAuth2 em cache.
OAUTH_TOKEN_CACHE_MARGIN_MS=30000
