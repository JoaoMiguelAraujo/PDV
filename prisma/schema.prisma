// Prisma schema do PDV (Software Service Open Delivery v1.7).
//
// Modela:
//  - Merchants (credenciais de cada empresa/unidade do menuGo que o PDV atende)
//  - OdEvents  (eventos crus recebidos via POST /v1/newEvent, validados por HMAC)
//  - Orders    (estado local de cada pedido — ciclo de vida no PDV)
//  - Callbacks (toda chamada de volta ao menuGo, com response/erro)
//  - Settings  (chave/valor global: auto_mode, delays, pay_on_confirm, etc.)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Merchant — uma linha por par (Ordering Application, restaurante).
//
// O cadastro é manual via /merchants pelo operador admin do PDV. Cada Merchant
// guarda TANTO o secret HMAC usado para validar o POST /v1/newEvent entrante,
// QUANTO o client_id/client_secret OAuth2 que o PDV usa para chamar o menuGo
// de volta. Em geral ambos vêm do menuGo no momento do cadastro da integração.
// =============================================================================
model Merchant {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(200)
  // Identificador OD (X-App-MerchantId / Merchant.id da spec). Mín 36 chars;
  // recomendado "CNPJ-UUID" (linha 3121 do openapi.yaml).
  merchantId         String    @unique @db.VarChar(100)
  // X-App-Id do menuGo (Ordering Application). UUID v4.
  appId              String    @db.VarChar(64)
  // HMAC do POST /v1/newEvent. Cifrado em repouso (formato enc:v1:<iv>.<ct>).
  clientSecretEnc    String    @db.Text
  menugoBaseURL      String    @db.VarChar(255)
  menugoClientId     String    @db.VarChar(64)
  menugoClientSecretEnc String @db.Text
  ativo              Boolean   @default(true)
  observacao         String?   @db.Text
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  // ===========================================================================
  // BasicInfo da spec OD v1.7 (schema 'BasicInfo' linha 3346 do openapi.yaml).
  // Campos required: name, document, corporateName, description,
  // averagePreparationTime, minOrderValue, merchantType, merchantCategories,
  // address, contactEmails, contactPhones, logoImage.
  //
  // merchantType é constante = 'RESTAURANT' (único enum aceito pela spec).
  // ===========================================================================
  // CNPJ — 14 dígitos (pattern ^\d{14}$ na spec).
  document           String?   @db.VarChar(14)
  corporateName      String?   @db.VarChar(500)
  description        String?   @db.Text
  averageTicket      Decimal?  @db.Decimal(10, 2)
  averagePreparationTime Int?
  minOrderValue      Decimal?  @db.Decimal(10, 2)
  // Array JSON de enum MerchantCategory (BURGERS|PIZZA|BBQ|...). Pelo menos 1.
  merchantCategoriesJson String? @db.Text
  // Endereço (spec 'Address' linha 5949). Todos required exceto reference.
  addressCountry     String?   @db.Char(2)
  addressState       String?   @db.VarChar(40)
  addressCity        String?   @db.VarChar(120)
  addressDistrict    String?   @db.VarChar(120)
  addressStreet      String?   @db.VarChar(200)
  addressNumber      String?   @db.VarChar(20)
  addressPostalCode  String?   @db.VarChar(20)
  addressComplement  String?   @db.VarChar(200)
  addressReference   String?   @db.VarChar(200)
  addressLatitude    Decimal?  @db.Decimal(10, 7)
  addressLongitude   Decimal?  @db.Decimal(10, 7)
  // Emails de contato (array JSON de strings).
  contactEmailsJson  String?   @db.Text
  // ContactPhones (spec linha 6077) — commercialNumber required, whatsapp opcional.
  contactCommercialNumber String? @db.VarChar(20)
  contactWhatsappNumber String? @db.VarChar(20)
  logoImageUrl       String?   @db.VarChar(500)
  bannerImageUrl     String?   @db.VarChar(500)
  // Cartões aceitos (array JSON de enum AcceptedCard). Optional na spec.
  acceptedCardsJson  String?   @db.Text
  // TTL em segundos (spec Merchant.TTL — min 500, max 86400).
  odTtl              Int       @default(500)

  events             OdEvent[]
  orders             Order[]
  categorias         Categoria[]
  produtos           Produto[]
  services           MerchantService[]
  mesas              Mesa[]
  comandas           Comanda[]

  @@index([ativo])
}

// =============================================================================
// MerchantService — fiel ao schema 'Service' (linha 3520 do openapi.yaml).
// Required: id (uuid), status, serviceType, menuId, serviceHours.
//
// menuId aponta para um Menu (entidade da spec) — como não modelamos múltiplos
// menus internamente, geramos um Menu sintético na hora do export contendo
// TODAS as categorias do merchant. O menuId aqui é o UUID estável desse menu.
//
// serviceHours e serviceArea são serializados como JSON dentro da linha para
// evitar explosão de tabelas (Hours/TimePeriods/HolidayHours/Polygon, etc.).
// =============================================================================
model MerchantService {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid()) @db.Char(36)
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   Int
  // DELIVERY | TAKEOUT | INDOOR
  serviceType  String   @db.VarChar(20)
  status       String   @default("AVAILABLE") @db.VarChar(20)
  // ServiceHours (spec linha 3797) — JSON: { id, weekHours: [{dayOfWeek[], timePeriods}], holidayHours? }
  serviceHoursJson String @db.Text
  // ServiceArea — só para DELIVERY. JSON do Polygon ou geoRadius.
  serviceAreaJson  String? @db.Text
  // serviceTiming opcional (INSTANT|SCHEDULED|ONDEMAND) — JSON.
  serviceTimingJson String? @db.Text
  // menuId — UUID do Menu sintético gerado por merchant. Constante por merchant.
  menuUuid     String   @db.Char(36)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([merchantId, ativo])
  @@unique([merchantId, serviceType])
}

// =============================================================================
// OdEvent — log cru de eventos recebidos no webhook /v1/newEvent.
// Persistido sempre, mesmo com HMAC inválido (audit trail).
// =============================================================================
model OdEvent {
  id                 Int       @id @default(autoincrement())
  merchant           Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  merchantId         Int?
  // Headers OD recebidos.
  appIdHeader        String    @db.VarChar(64)
  merchantIdHeader   String    @db.VarChar(100)
  signature          String    @db.VarChar(128)
  // Campos extraídos do body (se foi possível parsear).
  eventId            String?   @db.VarChar(64)
  eventType          String?   @db.VarChar(64)
  orderId            String?   @db.VarChar(64)
  orderURL           String?   @db.Text
  body               String    @db.LongText
  signatureValid     Boolean   @default(false)
  erro               String?   @db.Text
  // Resposta crua do GET no orderURL (best-effort, executado em background).
  orderDetail        String?   @db.LongText
  orderDetailStatus  Int?
  criadoEm           DateTime  @default(now())

  @@index([orderId])
  @@index([merchantId])
  @@index([eventType])
  @@index([criadoEm])
}

// =============================================================================
// Order — estado local do pedido no PDV.
//
// Criado/atualizado quando o GET no orderURL retorna 200 — sem isso não temos
// os items para mostrar na tela. Para um Event CREATED que ainda não conseguiu
// fetcheart a Order, a OdEvent fica registrada e o card aparece com warning.
// =============================================================================
model Order {
  id                 Int          @id @default(autoincrement())
  merchant           Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId         Int
  // UUID OD gerado pelo menuGo. Único globalmente.
  orderId            String       @unique @db.VarChar(64)
  // Campos da Order original — guardados parseados para query/listagem rápida.
  displayId          String?      @db.VarChar(40)
  orderType          String?      @db.VarChar(20)     // INDOOR | TAKEOUT | DELIVERY
  // Snapshot completo do JSON Order retornado pelo GET — verdade primária.
  rawOrder           String       @db.LongText
  status             OrderStatus  @default(NEW)
  // orderExternalCode devolvido ao menuGo no /confirm — em geral o número interno
  // do pedido no PDV. Gerado pelo PDV (sequencial por merchant).
  externalCode       String?      @db.VarChar(80)
  // Snapshot do total e mesa para listagem sem precisar parsear rawOrder.
  totalValor         Decimal?     @db.Decimal(10, 2)
  mesa               String?      @db.VarChar(40)
  cliente            String?      @db.VarChar(200)

  recebidoEm         DateTime     @default(now())
  confirmadoEm      DateTime?
  preparandoEm      DateTime?
  entregueEm        DateTime?
  canceladoEm        DateTime?
  cancelMotivo       String?      @db.Text
  cancelCode         String?      @db.VarChar(60)
  // Quando a OA dispara ORDER_CANCELLATION_REQUEST, marcamos aqui para o
  // operador decidir via /acceptCancellation ou /denyCancellation. Limpa
  // assim que o operador resolve.
  cancelRequested    Boolean      @default(false)
  cancelRequestedAt  DateTime?

  callbacks          Callback[]
  comanda            Comanda?

  @@index([merchantId, status])
  @@index([status, recebidoEm])
}

enum OrderStatus {
  NEW           // CREATED recebido, ainda não confirmado pelo PDV
  CONFIRMED     // PDV chamou /confirm
  PREPARING     // PDV chamou /preparing
  DELIVERED     // PDV chamou /delivered
  CANCELLED     // PDV chamou /requestCancellation (ou aceitou cancelamento da OA)
}

// =============================================================================
// Callback — log de toda chamada que o PDV faz ao menuGo (Ordering Application).
// =============================================================================
model Callback {
  id                 Int       @id @default(autoincrement())
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId            Int
  // confirm | preparing | delivered | requestCancellation | acceptCancellation | denyCancellation
  type               String    @db.VarChar(40)
  // Origem do disparo: MANUAL (botão no KDS) ou AUTO (auto-runner).
  triggeredBy        String    @default("MANUAL") @db.VarChar(20)
  requestBody        String?   @db.LongText
  httpStatus         Int?
  responseBody       String?   @db.LongText
  erro               String?   @db.Text
  criadoEm           DateTime  @default(now())

  @@index([orderId])
  @@index([type])
  @@index([criadoEm])
}

// =============================================================================
// Setting — config global chave/valor (persistente, sobrescreve env defaults).
// =============================================================================
model Setting {
  key       String    @id @db.VarChar(64)
  value     String    @db.Text
  updatedAt DateTime  @updatedAt
}

// =============================================================================
// Catálogo — Categoria, Produto, GrupoModificador, OpcaoModificador.
//
// Modela o cardápio mantido localmente pelo PDV. O menuGo pode importar este
// catálogo via GET /api/v1/menu (auth HMAC) — ver docs/pdv-integracao.md.
//
// codigoExterno é o SKU equivalente do produto no menuGo (alias do
// Order.items[].externalCode da spec OD). Permite mapeamento bidirecional.
// =============================================================================
model Categoria {
  id           Int      @id @default(autoincrement())
  // UUID exposto pela spec OD (campo Category.id é um UUID na spec). Gerado
  // automaticamente. Estável entre exports — usar como `externalCode` no
  // menuGo só faz sentido se você QUER que IDs se cruzem; em geral
  // `externalCode` recebe o nosso ID interno (mais legível em logs).
  uuid         String   @unique @default(uuid()) @db.Char(36)
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   Int
  nome         String   @db.VarChar(120)
  descricao    String?  @db.Text
  ordem        Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  produtos     Produto[]

  @@index([merchantId, ativo])
  @@index([merchantId, ordem])
}

model Produto {
  id            Int       @id @default(autoincrement())
  // UUID exposto pela spec OD — vira `Item.id` E `ItemOffer.itemId` no Menu
  // exportado por GET /v1/merchant.
  uuid          String    @unique @default(uuid()) @db.Char(36)
  // UUID separado para `ItemOffer.id` da spec — Item e ItemOffer têm IDs
  // distintos no modelo OD. Mantemos um único Produto interno; o offer UUID
  // é só uma identidade extra estável.
  offerUuid     String    @unique @default(uuid()) @db.Char(36)
  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId    Int
  categoria     Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  categoriaId   Int?
  nome          String    @db.VarChar(200)
  descricao     String?   @db.Text
  preco         Decimal   @db.Decimal(10, 2)
  // SKU interno do PDV (único por merchant). Usado para integração de estoque
  // e impressão de comanda.
  sku           String?   @db.VarChar(80)
  // Código externo (vira Order.items[].externalCode quando o pedido fluir pelo
  // menuGo). Pode ser igual ao SKU ou diferente, a critério do operador.
  codigoExterno String?   @db.VarChar(100)
  unidade       String    @default("UN") @db.VarChar(10)
  fotoUrl       String?   @db.VarChar(500)
  // Tempo médio de preparo em minutos — informativo. Quando o PDV confirma
  // um pedido, esse valor pode ser usado em OrderConfirmed.preparationTime.
  preparoMin    Int?
  ativo         Boolean   @default(true)
  ordem         Int       @default(0)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  grupos        GrupoModificador[]
  itensComanda  ItemComanda[]

  @@index([merchantId, ativo])
  @@index([categoriaId])
  @@index([merchantId, sku])
}

// =============================================================================
// GrupoModificador — agrupa opções (ex.: "Tamanho", "Adicionais").
// `min`/`max` definem regras de escolha (ex.: tamanho min=1 max=1, adicionais
// min=0 max=3). `obrigatorio` é equivalente a min>=1, mantido para clareza.
// =============================================================================
model GrupoModificador {
  id           Int       @id @default(autoincrement())
  // UUID exposto na spec como `OptionGroup.id`.
  uuid         String    @unique @default(uuid()) @db.Char(36)
  produto      Produto   @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  produtoId    Int
  nome         String    @db.VarChar(120)
  min          Int       @default(0)
  max          Int       @default(1)
  obrigatorio  Boolean   @default(false)
  ordem        Int       @default(0)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  opcoes       OpcaoModificador[]

  @@index([produtoId])
}

// =============================================================================
// Operação local — Mesa, Comanda, ItemComanda, Pagamento.
//
// NÃO é parte do schema Open Delivery (a spec OD cobre só pedidos vindos da
// OA). Estes modelos são puramente internos do PDV para:
//  - atendimento de salão (mesa, comanda eletrônica)
//  - registro de pagamento local (dinheiro/pix/cartão — sem fiscal por ora)
//
// Quando um pedido OD chega via /v1/newEvent → ingest cria Order; nada
// automático cria Comanda. Para mesas onde a OA externa entrega, manter
// Comanda local em paralelo é responsabilidade do operador (caso de uso raro
// e fora de escopo do MVP).
// =============================================================================
model Mesa {
  id           Int       @id @default(autoincrement())
  merchant     Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   Int
  numero       String    @db.VarChar(20)
  capacidade   Int?
  ativo        Boolean   @default(true)
  observacao   String?   @db.Text
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  comandas     Comanda[]

  @@unique([merchantId, numero])
  @@index([merchantId, ativo])
}

enum ComandaStatus {
  ABERTA
  FECHADA
  CANCELADA
}

model Comanda {
  id              Int            @id @default(autoincrement())
  // Código curto para o operador ditar/anotar (ex.: A0042).
  codigo          String         @unique @db.VarChar(20)
  merchant        Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId      Int
  mesa            Mesa?          @relation(fields: [mesaId], references: [id], onDelete: SetNull)
  mesaId          Int?
  status          ComandaStatus  @default(ABERTA)
  clienteNome     String?        @db.VarChar(200)
  clienteTelefone String?        @db.VarChar(40)
  clienteDocumento String?       @db.VarChar(20)
  // Observação geral (ex.: "sem cebola em tudo", "aniversário do João")
  observacao      String?        @db.Text
  // Subtotal calculado a partir dos itens (snapshot persistido para listagens
  // rápidas; recalculado a cada mutação).
  subtotal        Decimal        @default(0) @db.Decimal(10, 2)
  // Taxa de serviço (10% típica) calculada sobre subtotal — opcional.
  taxaServico     Decimal        @default(0) @db.Decimal(10, 2)
  desconto        Decimal        @default(0) @db.Decimal(10, 2)
  total           Decimal        @default(0) @db.Decimal(10, 2)
  totalPago       Decimal        @default(0) @db.Decimal(10, 2)
  // Se a comanda foi gerada por um pedido OD da OA (rare), aponta para Order.
  order           Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId         Int?           @unique
  abertaEm        DateTime       @default(now())
  fechadaEm       DateTime?
  cancelMotivo    String?        @db.Text

  itens           ItemComanda[]
  pagamentos      Pagamento[]

  @@index([merchantId, status])
  @@index([mesaId, status])
}

enum ItemComandaStatus {
  PENDENTE
  PREPARANDO
  PRONTO
  ENTREGUE
  CANCELADO
}

model ItemComanda {
  id              Int                @id @default(autoincrement())
  comanda         Comanda            @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  comandaId       Int
  produto         Produto?           @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  produtoId       Int?
  // Snapshot — preserva nome/preço mesmo se o produto sumir do catálogo.
  nomeSnapshot    String             @db.VarChar(200)
  precoSnapshot   Decimal            @db.Decimal(10, 2)
  quantidade      Decimal            @db.Decimal(10, 3) @default(1)
  // Soma de precoAdicional das opções escolhidas.
  acrescimoOpcoes Decimal            @db.Decimal(10, 2) @default(0)
  total           Decimal            @db.Decimal(10, 2)
  observacao      String?            @db.Text
  status          ItemComandaStatus  @default(PENDENTE)
  // JSON com [{ grupoId, opcaoId, nome, preco }] — preserva opções escolhidas.
  opcoesJson      String?            @db.Text
  adicionadoEm    DateTime           @default(now())
  atualizadoEm    DateTime           @updatedAt

  @@index([comandaId, status])
  @@index([produtoId])
}

enum MetodoPagamento {
  DINHEIRO
  PIX
  CREDITO
  DEBITO
  VOUCHER
  OUTRO
}

model Pagamento {
  id            Int             @id @default(autoincrement())
  comanda       Comanda         @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  comandaId     Int
  metodo        MetodoPagamento
  valor         Decimal         @db.Decimal(10, 2)
  // Troco devolvido (relevante só para DINHEIRO).
  troco         Decimal         @default(0) @db.Decimal(10, 2)
  // Identificador externo (ex.: transactionId de máquina de cartão, end-to-end
  // do PIX). Opcional.
  transactionId String?         @db.VarChar(120)
  observacao    String?         @db.Text
  registradoEm  DateTime        @default(now())

  @@index([comandaId])
  @@index([metodo, registradoEm])
}

model OpcaoModificador {
  id             Int       @id @default(autoincrement())
  // UUID exposto na spec como `Option.id`.
  uuid           String    @unique @default(uuid()) @db.Char(36)
  grupo          GrupoModificador @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  grupoId        Int
  nome           String    @db.VarChar(120)
  // Soma ao preço do produto base quando essa opção é escolhida. Pode ser
  // negativo (ex.: "Sem queijo: R$ -2,00") se o operador quiser modelar assim.
  precoAdicional Decimal   @db.Decimal(10, 2) @default(0)
  sku            String?   @db.VarChar(80)
  codigoExterno  String?   @db.VarChar(100)
  ativo          Boolean   @default(true)
  ordem          Int       @default(0)
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  @@index([grupoId, ativo])
}
