{
  "name": "pdv-opendelivery",
  "version": "1.0.0",
  "private": true,
  "description": "PDV (Software Service) compatível com Open Delivery v1.7 — recebe pedidos via webhook HMAC e devolve callbacks OAuth2 ao Ordering Application.",
  "scripts": {
    "dev": "next dev -p ${PORT:-4003}",
    "build": "prisma generate && next build",
    "start": "HOSTNAME=0.0.0.0 PORT=${PORT:-4003} node .next/standalone/server.js",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "bcrypt": "^6.0.0",
    "next": "^16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "prisma": "^6.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
